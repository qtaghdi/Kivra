{
  "name": "kivra-workspace",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @kivra/desktop dev",
    "web:dev": "pnpm --filter @kivra/web dev",
    "build": "pnpm --filter @kivra/desktop build",
    "web:build": "pnpm --filter @kivra/web build",
    "preview": "pnpm --filter @kivra/desktop preview",
    "desktop:tauri:dev": "pnpm --filter @kivra/desktop tauri:dev",
    "desktop:tauri:build": "pnpm --filter @kivra/desktop tauri:build",
    "jetbrains:build": "cd plugins/jetbrains && ./gradlew buildPlugin",
    "jetbrains:test": "cd plugins/jetbrains && ./gradlew test",
    "jetbrains:run-ide": "cd plugins/jetbrains && ./gradlew runIde",
    "vscode:build": "pnpm --filter kivra-vscode build",
    "vscode:check": "pnpm --filter kivra-vscode check",
    "vscode:test": "pnpm --filter kivra-vscode test",
    "vscode:package": "pnpm --filter kivra-vscode package",
    "protocol:check": "node tools/validate-protocol-fixtures.mjs",
    "trace:diagnose": "node tools/trace-diagnose.mjs",
    "trace:install-shell": "node tools/install-shell-capture.mjs"
  },
  "packageManager": "pnpm@11.9.0"
}
