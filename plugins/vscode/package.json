{
  "name": "kivra-vscode",
  "displayName": "Kivra",
  "description": "Capture VS Code Run and Debug console output for Kivra.",
  "version": "0.1.0",
  "private": true,
  "publisher": "kivra",
  "license": "UNLICENSED",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "onDebug"
  ],
  "main": "./out/extension.js",
  "icon": "resources/icon.png",
  "extensionKind": [
    "workspace"
  ],
  "files": [
    "out/**",
    "resources/**",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm build && node --test test/*.mjs",
    "package": "pnpm build && mkdir -p build && vsce package --no-dependencies --allow-missing-repository --out build/kivra-vscode-0.1.0.vsix"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.6.3"
  }
}
